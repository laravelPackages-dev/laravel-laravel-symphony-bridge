{
    "name": "matiascorrea007/laravel-laravel-symphony-bridge",
    "description": "Symphony event bridge for Laravel applications. Provides seamless event dispatching and listening across service boundaries.",
    "keywords": ["laravel", "symphony", "events", "bridge", "dispatcher"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Laravel\\SymphonyBridge\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laravel\\SymphonyBridge\\SymphonyBridgeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
